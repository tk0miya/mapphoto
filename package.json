    "ci": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "libheif-js": "^1.19.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "typescript": "^5.4.5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
